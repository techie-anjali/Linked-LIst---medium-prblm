class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {
        ListNode fast = head;
        ListNode slow = head;

        // Step 1: move fast n steps ahead
        for (int i = 0; i < n; i++) {
            fast = fast.next;
        }

        // Step 2: if fast is null → delete head
        if (fast == null) {
            return head.next;
        }

        // Step 3: move both pointers
        while (fast.next != null) {
            slow = slow.next;
            fast = fast.next;
        }

        // Step 4: delete node
        slow.next = slow.next.next;

        return head;
    }
}
